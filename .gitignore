# Dependencies and package-manager files
/node_modules/
/.pnp/
.pnp.*
/.yarn/*
!/.yarn/patches
!/.yarn/plugins
!/.yarn/releases
!/.yarn/versions

# Next.js, Turbopack, and build output
/.next/
/.turbo/
/out/
/build/
/dist/

# Test and TypeScript output
/coverage/
*.tsbuildinfo
next-env.d.ts

# Prisma generated clients and native engines.
# Keep prisma/schema.prisma and prisma/migrations/ under version control.
/src/generated/prisma/
/src/generated/prisma-client/
*.db
*.db-journal

# Environment files (commit .env.example only)
.env
.env.*
!.env.example

# Logs and debug output
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Hosting and local tooling
/.vercel/
/.idea/
.vscode/*
!/.vscode/extensions.json
!/.vscode/settings.json

# Operating-system files and local secrets
.DS_Store
Thumbs.db
*.pem
*.key
